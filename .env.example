# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/linguamaster
PGHOST=localhost
PGPORT=5432
PGDATABASE=linguamaster
PGUSER=username
PGPASSWORD=password

# AI Services
# Keep only if you still use direct Google APIs outside Gemini.
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Application Configuration
NODE_ENV=development
PORT=5000
LOG_LEVEL=INFO
LOG_FORMAT=text
LOG_SERVICE_NAME=linguamaster-api
LOG_WEBHOOK_URL=
UPTIME_ALERT_WEBHOOK_URL=
ALLOWED_ORIGINS=http://localhost:5000,http://localhost:3000

# Security
SESSION_SECRET=your_super_secret_session_key_here
JWT_SECRET=your_super_secret_jwt_secret_here
GOOGLE_WEB_CLIENT_ID=your_google_web_client_id_here
FRONTEND_URL=http://localhost:5000
APP_BASE_URL=http://localhost:5000

# Stripe Payments (optional - falls back to simulated purchases when unset)
STRIPE_SECRET_KEY=sk_test_your_secret_key_here

# Rate Limiting
API_RATE_LIMIT=100
AUTH_RATE_LIMIT=5
AI_RATE_LIMIT=10

# Learning economy tunables
FREE_LESSONS_PER_DAY=5
HEARTS_PER_EXTRA_LESSON=1
LEGENDARY_GEM_COST=100
